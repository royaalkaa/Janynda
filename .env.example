# Django
SECRET_KEY=your-secret-key-here-change-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,testserver,.ngrok-free.dev
ENABLE_DEBUG_TOOLBAR=False

# Database
DATABASE_URL=sqlite:///db.sqlite3

# Optional external services. Defaults below keep the project working with only runserver.
USE_REDIS=False
REDIS_URL=
CELERY_TASK_ALWAYS_EAGER=True
JANYNDA_INPROCESS_SCHEDULER_ENABLED=True

# PostgreSQL example, if you deploy it later:
# POSTGRES_DB=janynda
# POSTGRES_USER=janynda
# POSTGRES_PASSWORD=janynda
# DATABASE_URL=postgresql://janynda:janynda@localhost:5432/janynda

# Redis/Celery example, if you deploy them later:
# USE_REDIS=True
# REDIS_URL=redis://localhost:6379/0
# CELERY_TASK_ALWAYS_EAGER=False
# JANYNDA_INPROCESS_SCHEDULER_ENABLED=False

# Email (для алертов)





EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your@gmail.com
EMAIL_HOST_PASSWORD=your-app-password
DEFAULT_FROM_EMAIL=Janynda <your@gmail.com>

# OpenWeatherMap
OPENWEATHER_API_KEY=your-openweathermap-key

# OpenAI
OPENAI_API_KEY=your-openai-key

# Media
MEDIA_URL=/media/
